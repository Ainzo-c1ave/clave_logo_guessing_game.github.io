<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/game_bg"
    tools:context=".MainActivity">

    <View
        android:id="@+id/vignetteShadow"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginEnd="1dp"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0" />

    <EditText
        android:id="@+id/editTextGuessInput"
        android:layout_width="270dp"
        android:layout_height="60dp"
        android:ems="10"
        android:inputType="text"
        android:textColor="@color/game_bg"
        android:hint="Type your guess here"
        android:textColorHint="#888888"
        android:background="@drawable/custom_button_bg"
        app:backgroundTint="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.496"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.597" />


    <ImageView
        android:id="@+id/image_Guess"
        android:layout_width="270dp"
        android:layout_height="270dp"
        android:background="@drawable/white_rounded_bg"
        android:padding="24dp"
        android:scaleType="fitCenter"
        android:elevation="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.221"
        app:srcCompat="@drawable/antoks_logo" />

    <Button
        android:id="@+id/buttonGuess"
        android:layout_width="270dp"
        android:layout_height="55dp"
        android:background="@drawable/custom_button_bg"
        android:text="Guess!"
        android:textColor="@color/game_bg"
        android:textSize="20sp"
        app:backgroundTint="@null"
        app:cornerRadius="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.496"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.809" />

    <include layout="@layout/layout_settings" />

</androidx.constraintlayout.widget.ConstraintLayout>