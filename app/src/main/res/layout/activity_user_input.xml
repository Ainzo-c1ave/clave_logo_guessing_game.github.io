<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/game_bg">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My Quizzes"
            android:textColor="@color/primary_ui"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="16dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/quizListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
            </LinearLayout>
        </ScrollView>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#444444"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/etQuizTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter Quiz Title:"
            android:background="@drawable/white_rounded_bg"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            android:textColor="@color/box_text"
            android:textColorHint="#888888"/>

        <LinearLayout
            android:id="@+id/layoutTextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <EditText
                android:id="@+id/etTextQuestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/white_rounded_bg"
                android:hint="Enter Starter Question"
                android:padding="12dp"
                android:layout_marginBottom="8dp"
                android:textColor="@color/box_text"
                android:textColorHint="#888888"/>

            <EditText
                android:id="@+id/etTextAnswer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/white_rounded_bg"
                android:hint="Enter Starter Answer"
                android:padding="12dp"
                android:textColor="@color/box_text"
                android:textColorHint="#888888"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutImageInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <Button
                android:id="@+id/btnPickImage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Select an Image"
                android:textColor="@color/box_text"
                android:background="@drawable/white_rounded_bg"
                app:backgroundTint="@null"/>

            <EditText
                android:id="@+id/etImageQuestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/white_rounded_bg"
                android:hint="Enter Starter Question"
                android:padding="12dp"
                android:layout_marginTop="8dp"
                android:textColor="@color/box_text"
                android:textColorHint="#888888"/>

            <EditText
                android:id="@+id/etImageAnswer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/white_rounded_bg"
                android:hint="Enter Starter Answer"
                android:padding="12dp"
                android:layout_marginTop="8dp"
                android:textColor="@color/box_text"
                android:textColorHint="#888888"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnMainAction"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Add Quiz"
            android:textSize="18sp"
            android:background="@drawable/custom_button_bg"
            android:textColor="@color/game_bg"
            app:backgroundTint="@null"
            android:layout_marginTop="12dp"/>
    </LinearLayout>

    <!-- Settings Overlay -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <include layout="@layout/layout_settings" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>